# Server
PORT=4000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:5173

# PostgreSQL (AWS RDS or local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=school_erp

# Schema management: migrations are the source of truth. Leave unset (off).
# Local-dev opt-in only — set to 'true' to let TypeORM auto-sync the schema
# from entities. NEVER set in production (it is force-disabled there anyway).
# DB_SYNCHRONIZE=false

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRY=7d

# School
DEFAULT_SCHOOL_ID=school_001
# Prefix for auto-generated student Admission Numbers (e.g. JS -> JS-2026-0001)
ADMISSION_PREFIX=JS
